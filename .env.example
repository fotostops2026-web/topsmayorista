# ─────────────────────────────────────────────────────────
# LOCAL: Copiá este archivo como ".env" y completalo
# RAILWAY: Cargá estas variables en el panel de Railway
# ─────────────────────────────────────────────────────────

# URL de tu tienda Tiendanube (sin barra al final)
STORE_URL=https://tops19.mitiendanube.com

# Contraseña para el panel admin
ADMIN_PASS=admin2026

# Puerto (Railway lo asigna automáticamente, no tocar)
PORT=3000

# ── UPSTASH REDIS (persistencia en producción) ────────────
# Obtener en: https://console.upstash.com → Create Database
# Necesitás: REST URL y REST Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── OPCIONAL: API de Tiendanube ───────────────────────────
# Si los completás, sincroniza vía API (más rápido).
# Si no, usa scraping automático.
TN_STORE_ID=
TN_TOKEN=
